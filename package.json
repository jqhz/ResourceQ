{
  "name": "resourceq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix",
    "lint:check": "eslint .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "NODE_OPTIONS=--experimental-vm-modules dotenv jest --detectOpenHandles --forceExit",
    "drizzle:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "auth-schema:generate": "node --env-file=.env npx @better-auth/cli@latest generate --output src/server/db/schema/auth.ts --config src/server/auth.ts",
    "drizzle:migrate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "drizzle:check": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs check",
    "backfill:playlist-slugs": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/backfill-playlist-slugs.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.4.2",
    "next": "^16.2.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.78.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
